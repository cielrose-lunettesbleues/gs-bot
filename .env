# === TWITCH ===
# TWITCH_MOCK=true : démarre sans connexion Twitch, dashboard + simulateur uniquement
TWITCH_MOCK=true
TWITCH_CHANNEL=
TWITCH_BOT_USERNAME=
TWITCH_OAUTH_TOKEN=

# === OBS (mode simulé, pas besoin d'OBS installé) ===
OBS_MOCK=true
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=
OBS_SCENE_NAME=Main
OBS_SOURCE_NAME=GreenScreenSource

# === COMMANDES ===
GS_COMMAND=!gs
GS_STOP_COMMAND=!gstop

# === ACCÈS (tout ouvert pour les tests) ===
GS_SUB_ONLY=false
GS_MOD_ONLY=false

# === COOLDOWN (désactivé pour tester librement) ===
GS_COOLDOWN_ENABLED=false
GS_COOLDOWN_SECONDS=60
GS_COOLDOWN_PER_USER=false
GS_COOLDOWN_PER_USER_SECONDS=30

# === LECTURE ===
GS_DURATION_SECONDS=8
GS_CHAT_FEEDBACK=true

# === FILE D'ATTENTE ===
GS_QUEUE_MODE=queue
GS_QUEUE_MAX_SIZE=5

# === VALIDATION URL ===
GS_ALLOWED_DOMAINS=youtube.com,youtu.be,streamable.com,tenor.com,giphy.com
GS_ALLOW_DIRECT_FILES=true
GS_ALLOWED_FILE_EXTENSIONS=.mp4,.webm,.mov

# === DASHBOARD HTTP ===
CONTROL_HTTP_ENABLED=true
CONTROL_HTTP_HOST=127.0.0.1
CONTROL_HTTP_PORT=4317
CONTROL_HTTP_TOKEN=test123

# === YOUTUBE ===
GS_YOUTUBE_API_KEY=AIzaSyDnBu_11B8RGnkBhoJkGc7iN1RXSSj3SqU
# === GIPHY (GIF search) — cle gratuite sur developers.giphy.com ===
GS_GIPHY_API_KEY=
GS_MAX_VIDEO_DURATION_SECONDS=0

# === APPROBATION MOD ===
GS_MOD_APPROVAL=false
GS_MOD_APPROVAL_TIMEOUT=60

# === DONNÉES PERSISTANTES ===
GS_DATA_DIR=./data

# === LOGS ===
LOG_LEVEL=debug

# === CHANNEL POINTS (désactivé) ===
CHANNEL_POINTS_ENABLED=false
TWITCH_CLIENT_ID=
TWITCH_USER_ACCESS_TOKEN=
TWITCH_BROADCASTER_ID=
CHANNEL_POINTS_REWARD_ID=
