TWITCH_CHANNEL=mychannel
TWITCH_BOT_USERNAME=mybot
TWITCH_OAUTH_TOKEN=oauth:xxxxxxxxxxxx

# Set OBS_MOCK=true to run without OBS (simulates actions in logs)
OBS_MOCK=false
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=your_password
OBS_SCENE_NAME=Main
OBS_SOURCE_NAME=GreenScreenSource

GS_COMMAND=!gs
GS_STOP_COMMAND=!gstop

GS_SUB_ONLY=true
GS_MOD_ONLY=false

GS_COOLDOWN_ENABLED=true
GS_COOLDOWN_SECONDS=60
GS_COOLDOWN_PER_USER=false
GS_COOLDOWN_PER_USER_SECONDS=30

GS_DURATION_SECONDS=15
GS_CHAT_FEEDBACK=true

# Queue mode: queue (sequential), replace (new URL replaces current), drop (ignore if busy)
GS_QUEUE_MODE=queue
GS_QUEUE_MAX_SIZE=3

GS_ALLOWED_DOMAINS=youtube.com,youtu.be,streamable.com,tenor.com,giphy.com
GS_ALLOW_DIRECT_FILES=true
GS_ALLOWED_FILE_EXTENSIONS=.mp4,.webm,.mov

CONTROL_HTTP_ENABLED=false
CONTROL_HTTP_HOST=127.0.0.1
CONTROL_HTTP_PORT=4317
CONTROL_HTTP_TOKEN=change_me_local_secret

# YouTube duration check (leave YOUTUBE_API_KEY empty to disable)
YOUTUBE_API_KEY=
GS_MAX_VIDEO_DURATION_SECONDS=120

# Moderation approval queue (mods must approve !gs requests from non-mods)
GS_MOD_APPROVAL=false
GS_MOD_APPROVAL_TIMEOUT=60

# Directory for persistent data files (blacklist, history). Default: current dir.
GS_DATA_DIR=.

LOG_LEVEL=info

# Channel points via Twitch EventSub (requires a Twitch app + user access token)
# Scope needed: channel:read:redemptions
# Get a token: https://twitchtokengenerator.com (select channel:read:redemptions)
CHANNEL_POINTS_ENABLED=false
TWITCH_CLIENT_ID=
TWITCH_USER_ACCESS_TOKEN=
TWITCH_BROADCASTER_ID=          # Leave empty to auto-resolve from TWITCH_CHANNEL
CHANNEL_POINTS_REWARD_ID=       # Leave empty to accept any channel point reward
