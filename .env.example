# ============================================================
# GS Bot — Configuration (mode serveur multi-streamers)
# ============================================================
# Copie ce fichier en .env et remplis les valeurs.
# Le serveur démarre sur http://localhost:4317/
# Chaque streamer se connecte via Twitch OAuth.
# ============================================================

# --- Serveur ---
PORT=4317
HOST=0.0.0.0
GS_DATA_DIR=./data
LOG_LEVEL=info

# --- Twitch OAuth App (obligatoire pour la connexion) ---
# Crée ton app sur https://dev.twitch.tv/console/apps
# Redirect URI : http://localhost:4317/auth/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:4317/auth/twitch/callback
